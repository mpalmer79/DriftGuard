# Public, browser-visible. Used for *read* traffic.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Server-side only. Phase 6.3 frontend auth proxy injects this as
# `Authorization: Bearer <token>` on every write that goes through
# /api/proxy. Leave unset in dev when the backend is open.
SENTINEL_API_TOKEN=

# Optional override for where the proxy itself dials the backend.
# Defaults to NEXT_PUBLIC_API_BASE; set this when the proxy needs
# a different hostname than the browser does (e.g. inside Docker
# Compose: SENTINEL_BACKEND_URL=http://backend:8000).
SENTINEL_BACKEND_URL=
